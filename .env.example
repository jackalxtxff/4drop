# Скопировать в .env и заполнить. .env в git не коммитится.

POSTGRES_USER=4drop
POSTGRES_PASSWORD=change-me
POSTGRES_DB=4drop
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8080

# Подпись JWT. Сгенерировать: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-32-byte-hex

# Ключ шифрования секретов маркетплейсов и пароля 4tochki в БД (Fernet).
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Потеря ключа = потеря всех сохранённых доступов. Хранить в секрет-хранилище, не в репозитории.
SECRETS_KEY=

# Кэш WSDL 4tochki (138 КБ + 98 XSD — тянуть на каждый вызов нельзя)
FOURTOCHKI_WSDL=http://api-b2b.4tochki.ru/WCF/ClientService.svc?wsdl
FOURTOCHKI_WSDL_CACHE=/cache/4tochki-wsdl.db

# Первый пользователь, создаётся при старте если таблица users пуста
BOOTSTRAP_USER_EMAIL=admin@example.com
BOOTSTRAP_USER_PASSWORD=change-me
